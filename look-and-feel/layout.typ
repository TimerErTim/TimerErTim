#let rem = 16pt

#let layout = (
  fontSize: (
    tiny: 0.7 * rem,
    small: 0.85 * rem,
    medium: 1 * rem,
    large: 1.15 * rem,
  ),
  lineHeight: (
    tiny: 1 * rem,
    small: 1.25 * rem,
    medium: 1.5 * rem,
    large: 1.75 * rem,
  ),
  radius: (
    small: 0 * rem,
    medium: 0.05 * rem,
    large: 0.1 * rem,
  ),
  borderWidth: (
    small: 1pt,
    medium: 1pt,
    large: 1pt,
  ),
)
