#let rem = 16pt

#let layout = (
  fontSize: (
    tiny: 0.7 * rem,
    small: 0.85 * rem,
    medium: 1 * rem,
    large: 1.15 * rem,
  ),
  lineHeight: (
    tiny: 1 * rem,
    small: 1.25 * rem,
    medium: 1.5 * rem,
    large: 1.75 * rem,
  ),
  radius: (
    small: 0.25 * rem,
    medium: 0.5 * rem,
    large: 0.75 * rem,
  ),
  borderWidth: (
    small: 1.5pt,
    medium: 2pt,
    large: 3pt,
  ),
  depth: (
    small: 1.5pt,
    medium: 2pt,
  ),
)
